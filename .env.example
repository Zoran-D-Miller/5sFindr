# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service-role key is SERVER ONLY — never expose to the browser.
# Used for trusted economy mutations (token commit/return/forfeit, attendance settle).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Paystack (ZAR subscriptions + token top-ups) ──────────
PAYSTACK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxx
# Create an R20/month plan in the Paystack dashboard (currency ZAR) and paste its code:
PAYSTACK_PLAN_CODE=PLN_xxxxxxxx

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
